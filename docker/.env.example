###########################################################
# EQ2EMu Docker — environment template
###########################################################
#
# Copy this file to `docker/.env` and fill in every value marked
# CHANGE_ME. The `.env` file is gitignored and must never be committed.
#
# Password generation (Linux):
#     openssl rand -hex 24
# Run once per CHANGE_ME line. All _PASSWORD values must be unique.
#
# Values here follow the upstream `.env.example` (vendored as
# `.env.upstream-example` in this directory for reference). Changes
# from upstream defaults are flagged with "### LOCAL CHANGE:" comments.
###########################################################

###########################################################
# Drivers
###########################################################
NETWORKS_DRIVER=bridge

###########################################################
# MySQL / MariaDB
###########################################################
MARIADB_DATABASE=eq2emu
MARIADB_USER=eq2emu
MARIADB_PASSWORD="CHANGE_ME"
MARIADB_ROOT_PASSWORD="CHANGE_ME"
MYSQL_HOST="mysql"

# EQ2EMu Login Server DB user
EQ2LS_DB_HOST="mysql"
EQ2LS_DB_USER="eq2ls"
EQ2LS_DB_PASSWORD="CHANGE_ME"
EQ2LS_DB_NAME="eq2ls"
EQ2LOGIN_DB_PORT=3306

# Dawn web monitor DB user
EQ2DAWN_DB_HOST="mysql"
EQ2DAWN_DB_USER="eq2dawn"
EQ2DAWN_DB_PASSWORD="CHANGE_ME"
EQ2DAWN_DB_NAME="eq2dawn_web"
EQ2DAWN_DB_PORT=3306

###########################################################
# Server
###########################################################
WORLD_WEBPORT=9002
LOGIN_WEBPORT=9101
WORLD_CLIENT_PORT=9001
LOGIN_CLIENT_PORT=9100
WEB_SERVER_PORT=2424

WORLD_NAME="Homelab"
WORLD_ACCOUNT_NAME="testlabs"
# WORLD_ACCOUNT_PASSWORD: world→login auth. Upstream's world server stores
# this in a `char[31]` buffer and silently truncates to 30 chars before
# hashing, while the login DB stores the hash of the full value — so any
# password longer than 30 chars will mismatch and world will fail to
# connect ("Bad password"). Use `openssl rand -hex 14` (→28 chars) or
# `openssl rand -hex 15` (→30 chars). All other _PASSWORD fields here
# can go longer.
WORLD_ACCOUNT_PASSWORD="CHANGE_ME"

# Dawn admin UI (https://127.0.0.1:2424) — this password logs you into the
# web admin. Keep it strong even though the UI is localhost-bound.
EQ2DAWN_ADMIN_PASSWORD="CHANGE_ME"

MKCERT_URL="https://github.com/FiloSottile/mkcert/releases/download/v1.4.3/mkcert-v1.4.3-linux-amd64"
MKCERT_FILE="mkcert-v1.4.3-linux-amd64"

WEB_CERTFILE="/eq2emu/certs/webcert.pem"
WEB_KEYFILE="/eq2emu/certs/webkey.pem"
WEB_CAFILE=""

EQ2WORLD_WEB_ADMIN="webadmin"
EQ2WORLD_WEB_PASSWORD="CHANGE_ME"
EQ2LOGIN_WEB_ADMIN="webadmin"
EQ2LOGIN_WEB_PASSWORD="CHANGE_ME"

EQ2DAWN_AUTORESTART_SERVER="1"

###########################################################
# World and login database packages (first-run seeds)
###########################################################
EQ2WORLD_DB_PKG="https://raw.githubusercontent.com/emagi/eq2emu-database/refs/heads/main/eq2emu_world_db.tar.gz"
EQ2WORLD_DB_FILE="eq2emu_world_db.tar.gz"
EQ2WORLD_DB_SQL="eq2emu.sql"
EQ2LOGIN_DB_PKG="https://raw.githubusercontent.com/emagi/eq2emu-database/refs/heads/main/eq2emu_login_db.tar.gz"
EQ2LOGIN_DB_FILE="eq2emu_login_db.tar.gz"
EQ2LOGIN_DB_SQL="eq2emuls.sql"

###########################################################
# Upstream build sources
###########################################################
PREMAKE5_PKG="https://github.com/premake/premake-core/releases/download/v5.0.0-beta2/premake-5.0.0-beta2-linux.tar.gz"
PREMAKE5_FILE="premake-5.0.0-beta2-linux.tar.gz"
RECAST_GIT="https://github.com/recastnavigation/recastnavigation.git"
FMT_GIT="https://github.com/fmtlib/fmt.git"
EQ2SOURCE_GIT="https://github.com/emagi/eq2emu.git"
EQ2CONTENT_GIT="https://github.com/emagi/eq2emu-content.git"
EQ2MAPS_GIT="https://github.com/emagi/eq2emu-maps.git"
EQ2DB_GIT="https://github.com/emagi/eq2emu-editor.git"
EQ2DAWN_GIT="https://github.com/emagi/eq2emu_dawnserver.git"

###########################################################
# Network binding
###########################################################
# IP_ADDRESS: what the server advertises to clients in the world list
# (becomes login_worldservers.ip_address). Must be reachable from every
# place a client lives:
#   * 127.0.0.1 only works for clients on the host itself.
#   * 192.168.122.1 works for the host AND for libvirt KVM guests on the
#     default `virbr0` bridge — that's our Phase-1 default since we run a
#     dedicated GM-account VM next to the server (see docs/gm-client-vm.md).
#   * Phase 3 will swap this to a LAN or VPN IP when friends connect.
IP_ADDRESS=192.168.122.1

# LISTEN_PORT_ADDRESS: which host interface docker binds the login/world
# UDP ports to. Keep at 127.0.0.1 until Phase 3 decides the remote access
# model (DNS-only A record vs. Tailscale vs. Cloudflare Spectrum).
LISTEN_PORT_ADDRESS=127.0.0.1

EQ2WORLD_LOGIN_IP=127.0.0.1
EQ2WORLD_LOGIN_PORT=9100

HOST_LOGIN=1

# GitHub token for the Dawn admin UI "Update Database" feature. Leave
# blank unless you specifically want that button to work; if set, this
# is a real credential — treat it like any other secret.
GITHUB_TOKEN=""

###########################################################
# EQ2EMu DB editor (web UI at http://127.0.0.1:${DBWEB_SERVER_PORT}/eq2db)
###########################################################
EQ2EDITOR_DB_PKG="https://raw.githubusercontent.com/emagi/eq2emu-editor/main/eq2editor.sql"
EQ2EDITOR_DB_FILE="eq2editor.sql"
EQ2EDITOR_DB_HOST="mysql"
EQ2EDITOR_DB_USER="eq2editor"
EQ2EDITOR_DB_PASSWORD="CHANGE_ME"
EQ2EDITOR_DB_NAME="eq2editor"
EQ2EDITOR_ADMIN_PASSWORD="CHANGE_ME"

### LOCAL CHANGE: upstream default is 80, which conflicts with an
### existing caddy container on this host. Using 8080 instead. If you
### change this, update docs/setup.md and any bookmarks.
DBWEB_SERVER_PORT=8080
LISTEN_DBWEB_ADDRESS=127.0.0.1

###########################################################
# Timezone
###########################################################
TZ="US/Central"
