\ No newline at end of file
+}
+
+int EQ2Emu_lua_BotCommand(lua_State* state) {
+	// Lua signature: BotCommand(caster, "subcmd args")
+	// Dispatches into Commands::Command_Bot as if the caster typed
+	// "/bot <subcmd args>". Used by the bot-control spell pack so
+	// player abilities can drive /bot prepull, /bot camp all, etc.
+	if (!lua_interface)
+		return 0;
+	Spawn* caster = lua_interface->GetSpawn(state);
+	string subcmd = lua_interface->GetStringValue(state, 2);
+	lua_interface->ResetFunctionStack(state);
+	if (!caster || !caster->IsPlayer() || subcmd.empty())
+		return 0;
+	Client* client = caster->GetClient();
+	if (!client)
+		return 0;
+	Seperator sep(subcmd.c_str(), ' ', 5, 100, true);
+	commands.Command_Bot(client, &sep);
+	return 0;
+}
