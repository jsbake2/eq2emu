+bool Bot::ShouldHoldDamage() {
+	if (!main_tank)
+		return false;        // legacy behavior when no tank set
+	if (main_tank == this)
+		return false;        // I am the tank — fire freely
+	Spawn* tgt = GetTarget();
+	if (!tgt || !tgt->IsNPC())
+		return false;
+	Entity* most_hated = ((NPC*)tgt)->Brain()->GetMostHated();
+	return most_hated != main_tank;
+}
