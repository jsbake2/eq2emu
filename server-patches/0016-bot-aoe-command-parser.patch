# Adds the actual /bot aoe on|off [<slot>|all] command parser branch.
#
# Patch 0015 added the help text, the m_aoeEnabled flag, the spell-filter
# logic, and the DB load/save helper, but NOT the command-handler else-if
# in BotCommands.cpp — so /bot aoe off all just printed the usage block
# without doing anything. This branch mirrors the /bot camp logic for
# target/slot/"all" resolution and persists via database.SaveBotAOE.
--- a/source/WorldServer/Bots/BotCommands.cpp	2026-04-29 23:12:50.860655536 -0500
+++ b/source/WorldServer/Bots/BotCommands.cpp	2026-04-29 23:12:50.878659519 -0500
@@ -98,6 +98,71 @@
 			client->Message(CHANNEL_COLOR_YELLOW, "Prepull primed on %d bot(s).", count);
 			return;
 		}
+		else if (strncasecmp("aoe", sep->arg[0], 3) == 0) {
+			// /bot aoe on|off [<slot>|all]
+			// No 3rd arg: act on currently targeted bot.
+			// 3rd arg = "all": every group bot the caller owns.
+			// 3rd arg = number: bot at that /bot list slot.
+			if (!sep->IsSet(1)) {
+				client->SimpleMessage(CHANNEL_COLOR_YELLOW, "Usage: /bot aoe on|off [<slot>|all]");
+				return;
+			}
+			bool enable;
+			if (strncasecmp("on", sep->arg[1], 2) == 0)
+				enable = true;
+			else if (strncasecmp("off", sep->arg[1], 3) == 0)
+				enable = false;
+			else {
+				client->SimpleMessage(CHANNEL_COLOR_YELLOW, "Usage: /bot aoe on|off [<slot>|all]");
+				return;
+			}
+
+			vector<Bot*> targets;
+			if (sep->IsSet(2) && strncasecmp("all", sep->arg[2], 3) == 0) {
+				GroupMemberInfo* gmi = client->GetPlayer()->GetGroupMemberInfo();
+				if (!gmi) {
+					client->SimpleMessage(CHANNEL_COLOR_YELLOW, "You are not in a group.");
+					return;
+				}
+				PlayerGroup* group = world.GetGroupManager()->GetGroup(gmi->group_id);
+				if (!group) return;
+				group->MGroupMembers.readlock(__FUNCTION__, __LINE__);
+				deque<GroupMemberInfo*>* members = group->GetMembers();
+				for (size_t i = 0; i < members->size(); i++) {
+					Entity* m = members->at(i)->member;
+					if (m && m->IsBot() && ((Bot*)m)->GetOwner() == client->GetPlayer())
+						targets.push_back((Bot*)m);
+				}
+				group->MGroupMembers.releasereadlock(__FUNCTION__, __LINE__);
+			}
+			else if (sep->IsSet(2) && sep->IsNumber(2)) {
+				int32 index = atoi(sep->arg[2]);
+				if (client->GetPlayer()->SpawnedBots.count(index) > 0) {
+					Spawn* sp = client->GetCurrentZone()->GetSpawnByID(client->GetPlayer()->SpawnedBots[index]);
+					if (sp && sp->IsBot()) targets.push_back((Bot*)sp);
+				}
+			}
+			else {
+				if (client->GetPlayer()->GetTarget() && client->GetPlayer()->GetTarget()->IsBot())
+					targets.push_back((Bot*)client->GetPlayer()->GetTarget());
+			}
+
+			if (targets.empty()) {
+				client->SimpleMessage(CHANNEL_COLOR_YELLOW, "Target a bot, or pass an id/all: /bot aoe on|off <slot>|all");
+				return;
+			}
+
+			int updated = 0;
+			for (Bot* b : targets) {
+				if (b->GetOwner() != client->GetPlayer()) continue;
+				b->SetAOEEnabled(enable);
+				database.SaveBotAOE(b);
+				updated++;
+			}
+			client->Message(CHANNEL_COLOR_YELLOW, "AoE %s for %d bot(s).",
+				enable ? "ENABLED" : "DISABLED", updated);
+			return;
+		}
 		else if (strncasecmp("attack", sep->arg[0], 6) == 0) {
 			if (client->GetPlayer()->GetTarget() && client->GetPlayer()->GetTarget()->IsEntity() && client->GetPlayer()->GetTarget()->Alive()) {
 				Entity* target = (Entity*)client->GetPlayer()->GetTarget();
